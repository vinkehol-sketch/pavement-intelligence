# ============================================================
# Pavement Intelligence — Variables de Entorno de Ejemplo
# ============================================================

PI_ENV=development
PI_DEBUG=true
PI_LOG_LEVEL=INFO
PI_DB_URL=sqlite:///./data/pavement_intelligence.db
PI_API_HOST=127.0.0.1
PI_API_PORT=8000
PI_API_RELOAD=true
PI_API_SECRET_KEY=cambia-esta-clave-en-produccion

PI_YOLO_MODEL_PATH=data/models/yolov8n.pt
PI_YOLO_CONFIDENCE_THRESHOLD=0.45
PI_YOLO_IOU_THRESHOLD=0.45
PI_YOLO_DEVICE=cpu

PI_TRACKER_TYPE=bytetrack
PI_ENABLE_PLATE_RECOGNITION=true
PI_PLATE_MIN_CONFIDENCE=0.60
PI_PLATE_ANONYMIZE=true
PI_PLATE_HASH_LENGTH=8
PI_ENABLE_SPEED_ESTIMATION=false
PI_SPEED_UNITS=km/h

PI_DEFAULT_SURVEY_HOURS=24
PI_EXPANSION_FACTOR_MODE=auto
PI_ESAL_STANDARD_AXLE_KN=80.0
PI_ESAL_AXLE_LOAD_UNITS=kN

PI_PAVEMENT_DEFAULT_RELIABILITY=85.0
PI_PAVEMENT_DEFAULT_SO=0.45
PI_PAVEMENT_DEFAULT_DELTA_PSI=1.7
PI_PAVEMENT_DEFAULT_DESIGN_PERIOD=20
